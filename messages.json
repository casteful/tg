    "examples": {
        "comment": "Below are example configurations you can copy",
        
        "example_1_latest_from_channel": {
            "description": "Get the latest video from a specific channel",
            "youtube_search": {
                "channel": "MrBeast",
                "sort_by": "latest",
                "max_results": 1,
                "template": "🎬 *Latest from MrBeast*\n\n{title}\n\n🔗 {link}"
            }
        },
        
        "example_2_popular_from_query": {
            "description": "Get most popular video for a search term",
            "youtube_search": {
                "query": "python tutorial 2024",
                "sort_by": "popular",
                "max_results": 10,
                "template": "📚 *Top Python Tutorial*\n\n🎬 {title}\n📺 {channel}\n👁️ {views}\n\n🔗 {link}"
            }
        },
        
        "example_3_search_in_channel": {
            "description": "Search for specific content within a channel",
            "youtube_search": {
                "channel": "Fireship",
                "query": "javascript",
                "sort_by": "latest",
                "max_results": 5,
                "template": "⚡ *Fireship JS*\n\n🎬 {title}\n\n🔗 {link}"
            }
        },
        
        "example_4_random_discovery": {
            "description": "Random video discovery for a topic",
            "youtube_search": {
                "query": "indie game devlog",
                "sort_by": "random",
                "max_results": 20,
                "template": "🎮 *Game Dev Discovery*\n\n🎬 {title}\n📺 {channel}\n\n🔗 {link}"
            }
        },
        
        "example_5_ue5_channel": {
            "description": "UE5 tutorials from official channel",
            "youtube_search": {
                "channel": "Unreal Engine",
                "query": "beginner tutorial",
                "sort_by": "latest",
                "max_results": 10,
                "template": "🎯 *UE5 Beginner*\n\n🎬 {title}\n⏱️ {duration}\n\n🔗 {link}"
            }
        },
        
        "example_6_channel_by_handle": {
            "description": "Using channel handle (@username)",
            "youtube_search": {
                "channel": "@LinusTechTips",
                "sort_by": "latest",
                "max_results": 5,
                "template": "💻 *Tech Tips*\n\n🎬 {title}\n📺 {channel}\n\n🔗 {link}"
            }
        }
    }
}
